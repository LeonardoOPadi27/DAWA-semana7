<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
  :root {
    --bg:       #0a0a0a;
    --surface:  #111111;
    --border:   #1f1f1f;
    --muted:    #2a2a2a;
    --text:     #c8c8c8;
    --dim:      #555;
    --accent:   #a3e635;
    --accent-d: #6b9e1f;
    --danger:   #ef4444;
    --mono:     'IBM Plex Mono', monospace;
    --sans:     'IBM Plex Sans', sans-serif;
    --radius:   2px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background:
      radial-gradient(circle at top, rgba(163,230,53,0.06), transparent 28%),
      radial-gradient(circle at bottom right, rgba(255,255,255,0.03), transparent 20%),
      var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  .app-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 52px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .app-nav__brand {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-transform: uppercase;
    text-decoration: none;
  }

  .app-nav__brand::before {
    content: '> ';
    opacity: 0.5;
  }

  .btn-logout {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
    background: none;
    border: 1px solid var(--border);
    padding: 5px 14px;
    cursor: pointer;
    border-radius: var(--radius);
    transition: color 0.15s, border-color 0.15s;
  }

  .btn-logout:hover {
    color: var(--danger);
    border-color: var(--danger);
  }

  /* ── CONTAINER ── */
  .app-main {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  /* ── TYPOGRAPHY ── */
  h2, h3, h4 {
    font-family: var(--mono);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #e8e8e8;
  }

  /* ── CARD ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  /* ── TABLE ── */
  .table {
    --bs-table-bg: transparent;
    --bs-table-color: var(--text);
    --bs-table-border-color: var(--border);
    font-family: var(--mono);
    font-size: 13px;
  }

  .table thead th {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    border-bottom: 1px solid var(--border);
    padding: 12px 16px;
    font-weight: 400;
  }

  .table tbody td {
    padding: 12px 16px;
    border-color: var(--border);
    vertical-align: middle;
  }

  .table tbody tr {
    transition: background 0.1s;
  }

  .table tbody tr:hover {
    background: var(--muted);
  }

  /* ── FORMS ── */
  .form-control {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--mono);
    font-size: 13px;
    padding: 10px 14px;
    transition: border-color 0.15s;
  }

  .form-control:focus {
    background: var(--bg);
    border-color: var(--accent);
    color: var(--text);
    box-shadow: none;
    outline: none;
  }

  .form-control::placeholder {
    color: var(--dim);
  }

  .form-control[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.3);
    cursor: pointer;
  }

  /* ── BUTTONS ── */
  .btn-primary, .btn-success {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--accent);
    color: #0a0a0a;
    border: none;
    border-radius: var(--radius);
    padding: 11px 20px;
    font-weight: 500;
    transition: opacity 0.15s, transform 0.1s;
    cursor: pointer;
  }

  .btn-primary:hover, .btn-success:hover {
    background: var(--accent);
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .btn-primary:active, .btn-success:active {
    transform: translateY(0);
  }

  /* ── LINKS ── */
  a {
    color: var(--accent);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 12px;
  }

  a:hover {
    color: var(--accent);
    opacity: 0.7;
  }

  /* ── PAGE LABEL ── */
  .page-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 6px;
  }

  .page-title {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 400;
    color: #e8e8e8;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 2px; }
</style>
</head>

<body>

<nav class="app-nav">
  <a class="app-nav__brand" href="#">JWT App</a>
  <button class="btn-logout" onclick="logout()">Salir</button>
</nav>

<main class="app-main">
  <%- include(bodyPartial || '../profile') %>
</main>

<script>
function logout() {
  sessionStorage.clear();
  window.location.href = "/signIn";
}
</script>

</body>
</html>
