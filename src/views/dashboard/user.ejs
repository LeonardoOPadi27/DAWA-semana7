<style>
  /* Welcome banner */
  .dashboard-welcome {
    background: linear-gradient(135deg, rgba(163,230,53,0.1), transparent);
    border: 1px solid rgba(163,230,53,0.2);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .welcome-text h3 {
    font-family: var(--mono);
    font-size: 18px;
    color: #e8e8e8;
    margin-bottom: 4px;
  }

  .welcome-text p {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.05em;
  }

  .welcome-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(163,230,53,0.12);
    border: 1px solid rgba(163,230,53,0.3);
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .welcome-badge::before {
    content: '●';
    color: var(--accent);
    font-size: 8px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .stat-card {
    background: linear-gradient(180deg, rgba(20,20,20,0.8), rgba(12,12,12,0.8));
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .stat-card:hover {
    border-color: rgba(163,230,53,0.3);
    transform: translateY(-2px);
  }

  .stat-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 10px;
  }

  .stat-value {
    font-family: var(--mono);
    font-size: 22px;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 8px;
  }

  .stat-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: #666;
  }

  /* Info sections */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }

  .profile-sidebar {
    background: linear-gradient(180deg, rgba(20,20,20,0.96), rgba(12,12,12,0.96));
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    height: fit-content;
  }

  .profile-img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent);
    margin: 0 auto 16px;
    display: block;
  }

  .profile-name {
    font-family: var(--mono);
    font-size: 14px;
    color: #e8e8e8;
    margin-bottom: 6px;
    font-weight: 500;
  }

  .profile-role {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .profile-status {
    display: inline-block;
    padding: 6px 12px;
    background: rgba(163,230,53,0.15);
    border: 1px solid rgba(163,230,53,0.3);
    border-radius: 6px;
    font-family: var(--mono);
    font-size: 9px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 18px;
  }

  .profile-divider {
    height: 1px;
    background: var(--border);
    margin: 16px 0;
  }

  .profile-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .profile-action-btn {
    padding: 10px 14px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .profile-action-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Info sections */
  .info-section {
    background: linear-gradient(180deg, rgba(20,20,20,0.96), rgba(12,12,12,0.96));
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }

  .section-title {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
  }

  .info-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 6px;
  }

  .info-value {
    font-family: var(--mono);
    font-size: 13px;
    color: #e8e8e8;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .dashboard-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
    .dashboard-welcome { flex-direction: column; gap: 12px; }
  }
</style>

<p class="page-label">Panel de control</p>
<h2 class="page-title">Tu Dashboard</h2>

<div id="dashboardContent" style="opacity: 0.7; padding: 20px; text-align: center;">
  <p style="font-family:var(--mono);font-size:12px;">Cargando dashboard...</p>
</div>

<script>
const token = sessionStorage.getItem('token');
if (!token) location.href = '/signIn';

async function loadDashboard() {
  try {
    const res = await fetch('/api/users/me', { headers: { Authorization: 'Bearer ' + token } });
    if (res.status === 401) return location.href = '/signIn';
    
    const u = await res.json();
    
    // Formatear fechas
    const birth = u.birthdate
      ? new Date(u.birthdate).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric'})
      : '—';
    
    const joined = u.createdAt
      ? new Date(u.createdAt).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric'})
      : '—';
    
    const avatar = u.url_profile || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(u.name+' '+u.lastName) + '&background=1f1f1f&color=a3e635&size=100';
    
    let roleName = 'user';
    if (u.roles && u.roles.length > 0) {
      roleName = (typeof u.roles[0] === 'string') ? u.roles[0] : (u.roles[0].name || 'user');
    }
    
    let html = '';
    
    // Welcome Banner
    html += '<div class="dashboard-welcome">';
    html += '<div class="welcome-text">';
    html += '<h3>¡Bienvenido de vuelta, ' + u.name + '!</h3>';
    html += '<p>Aquí está tu resumen personal y configuración de cuenta</p>';
    html += '</div>';
    html += '<div class="welcome-badge">En línea</div>';
    html += '</div>';
    
    // Stats Grid
    html += '<div class="stats-grid">';
    html += '<div class="stat-card">';
    html += '<p class="stat-label">Email</p>';
    html += '<p class="stat-value" style="font-size:14px;word-break:break-all;">' + u.email + '</p>';
    html += '<p class="stat-meta">Verificado</p>';
    html += '</div>';
    
    html += '<div class="stat-card">';
    html += '<p class="stat-label">Teléfono</p>';
    html += '<p class="stat-value" style="font-size:18px;">' + (u.phoneNumber || '—') + '</p>';
    html += '<p class="stat-meta">Contacto principal</p>';
    html += '</div>';
    
    html += '<div class="stat-card">';
    html += '<p class="stat-label">Miembro desde</p>';
    html += '<p class="stat-value" style="font-size:16px;">' + joined + '</p>';
    html += '<p class="stat-meta">Fecha de registro</p>';
    html += '</div>';
    
    html += '<div class="stat-card">';
    html += '<p class="stat-label">Rol</p>';
    html += '<p class="stat-value">' + roleName.toUpperCase() + '</p>';
    html += '<p class="stat-meta">Nivel de acceso</p>';
    html += '</div>';
    html += '</div>';
    
    // Main Content Grid
    html += '<div class="dashboard-grid">';
    
    // Profile Sidebar
    html += '<div class="profile-sidebar">';
    html += '<img class="profile-img" src="' + avatar + '" alt="Avatar">';
    html += '<p class="profile-name">' + u.name + ' ' + u.lastName + '</p>';
    html += '<p class="profile-role">' + roleName + '</p>';
    html += '<div class="profile-status">● Activo</div>';
    html += '<div class="profile-divider"></div>';
    html += '<div class="profile-actions">';
    html += '<button class="profile-action-btn" onclick="location.href=\'/profile\'">Editar Perfil</button>';
    html += '<button class="profile-action-btn" onclick="logout()">Cerrar Sesión</button>';
    html += '</div>';
    html += '</div>';
    
    // Info Sections
    html += '<div>';
    
    // Personal Info
    html += '<div class="info-section">';
    html += '<p class="section-title">Información Personal</p>';
    html += '<div class="info-grid">';
    
    html += '<div class="info-item">';
    html += '<p class="info-label">Nombre completo</p>';
    html += '<p class="info-value">' + u.name + ' ' + u.lastName + '</p>';
    html += '</div>';
    
    html += '<div class="info-item">';
    html += '<p class="info-label">Fecha de nacimiento</p>';
    html += '<p class="info-value">' + birth + '</p>';
    html += '</div>';
    
    html += '<div class="info-item">';
    html += '<p class="info-label">Dirección</p>';
    html += '<p class="info-value">' + (u.address || 'No especificada') + '</p>';
    html += '</div>';
    
    html += '<div class="info-item">';
    html += '<p class="info-label">Teléfono</p>';
    html += '<p class="info-value">' + u.phoneNumber + '</p>';
    html += '</div>';
    
    html += '</div>';
    html += '</div>';
    
    html += '</div>';
    html += '</div>';
    
    document.getElementById('dashboardContent').innerHTML = html;
  } catch(err) {
    document.getElementById('dashboardContent').innerHTML = 
      '<p style="color:#ef4444;font-family:var(--mono);">Error cargando dashboard: ' + err.message + '</p>';
  }
}

loadDashboard();
</script>
